<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingBottom="@dimen/activity_vertical_margin"
    android:paddingLeft="@dimen/activity_horizontal_margin"
    android:paddingRight="@dimen/activity_horizontal_margin"
    android:paddingTop="@dimen/activity_vertical_margin"
    tools:context="com.indrajha.sasquiz.WelcomeActivity">

    <RelativeLayout
        android:id="@+id/layoutUser"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_centerHorizontal="true"
        android:visibility="visible" >

        <TextView
            android:id="@+id/textView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="2dp"
            android:layout_marginLeft="2dp"
            android:layout_marginTop="64sp"
            android:text="@string/welcome"
            android:textColor="#F44336"
            android:textSize="24sp"/>

        <TextView
            android:id="@+id/textUser"
            android:layout_width="wrap_content"
            android:layout_height="35dp"
            android:layout_below="@id/textView"
            android:layout_marginTop="12dp"
            android:text="@string/invalid_user"
            android:textColor="#F4aa36"
            android:textSize="16sp" />

        <ImageView
            android:id="@+id/picUser"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxHeight="40dp"
            android:minHeight="40dp"
            android:visibility="visible"
            android:contentDescription="TODO" />

        <Button
            android:id="@+id/btnSignOut"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_alignParentRight="true"
            android:text="@string/sign_out"
            android:textSize="12sp"
            style="?android:attr/borderlessButtonStyle"
            android:textColor="#F44336"/>

    </RelativeLayout>

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/layoutUser">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical">

            <Button
                android:id="@+id/btnViewSyllabus"
                android:layout_width="240dp"
                android:layout_height="56dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/round_butt2"
                android:text="View Syllabus"
                android:textColor="#ffffff"
                android:textSize="20sp" />

            <Button
                android:id="@+id/btnReadBooks"
                android:layout_width="240dp"
                android:layout_height="56dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/round_butt3"
                android:text="Read Books"
                android:textColor="#ffffff"
                android:textSize="20sp" />

            <Button
                android:id="@+id/btnQuizTest"
                android:layout_width="240dp"
                android:layout_height="56dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/round_butt"
                android:text="Quiz Test"
                android:textColor="#ffffff"
                android:textSize="20sp" />

            <Button
                android:id="@+id/btnNotesBookmarks"
                android:layout_width="240dp"
                android:layout_height="56dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/round_butt2"
                android:text="Notes / Bookmarks"
                android:textColor="#ffffff"
                android:textSize="20sp" />


            <LinearLayout
                android:id="@+id/quizSelectionLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- Category 1: Part 1 -->
            <RadioButton
                android:id="@+id/rbPart1"
                android:layout_width="wrap_content"
                android:layout_height="35dp"
                android:layout_marginTop="36dp"
                android:text="@string/choose_paper1"
                android:checked="true" />

            <Spinner
                android:id="@+id/spinner1"
                android:layout_width="240dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:contentDescription="@string/choose_paper1"
                android:minHeight="48dp" />

            <!-- Category 2: Part 1 Book wise -->
            <RadioButton
                android:id="@+id/rbBookWise"
                android:layout_width="wrap_content"
                android:layout_height="35dp"
                android:layout_marginTop="24dp"
                android:text="@string/choose_p1_s" />

            <Spinner
                android:id="@+id/spinner2"
                android:layout_width="240dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:contentDescription="@string/choose_paper2"
                android:enabled="false"
                android:alpha="0.5"
                android:minHeight="48dp" />

            <!-- Category 3: Part 2 -->
            <RadioButton
                android:id="@+id/rbPart2"
                android:layout_width="wrap_content"
                android:layout_height="35dp"
                android:layout_marginTop="24dp"
                android:text="@string/choose_paper2" />

            <Spinner
                android:id="@+id/spinner3"
                android:layout_width="240dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:contentDescription="@string/choose_paper2"
                android:enabled="false"
                android:alpha="0.5"
                android:minHeight="48dp" />

            <!-- Category 4: Latest Questions -->
            <RadioButton
                android:id="@+id/rbLatest"
                android:layout_width="wrap_content"
                android:layout_height="35dp"
                android:layout_marginTop="24dp"
                android:text="Latest Questions" />

            <Spinner
                android:id="@+id/spinnerLatest"
                android:layout_width="240dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:contentDescription="Latest Questions"
                android:enabled="false"
                android:alpha="0.5"
                android:minHeight="48dp" />

            <TextView
                android:id="@+id/selPaper"
                android:layout_width="wrap_content"
                android:layout_height="20dp"
                android:layout_marginTop="48dp"
                android:layout_marginBottom="50dp"
                android:text="@string/selected_paper_name" />

            <Button
                android:id="@+id/btnStart1"
                android:layout_width="200dp"
                android:layout_height="48dp"
                android:layout_marginStart="-2dp"
                android:layout_marginLeft="-2dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/round_butt"
                android:text="@string/start"
                android:textColor="#ffffff"
                android:textSize="30sp" />

            </LinearLayout>

            <Button
                android:id="@+id/btnChangelog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:layout_marginBottom="20dp"
                android:layout_marginHorizontal="20dp"
                android:background="@drawable/round_butt3"
                android:text="changelog"
                android:textColor="#4E342E" />
        </LinearLayout>
    </ScrollView>
</RelativeLayout>
